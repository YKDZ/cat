{
  "name": "@cat/app-api",
  "version": "0.1.0",
  "keywords": [
    "cat",
    "plugins",
    "types",
    "typescript"
  ],
  "license": "MIT",
  "files": [
    "dist",
    "package.json"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./app": {
      "types": "./dist/app.d.ts",
      "import": "./dist/app.js"
    },
    "./orpc/router": {
      "types": "./dist/orpc/router.d.ts",
      "import": "./dist/orpc/router.js"
    },
    "./context": {
      "types": "./dist/utils/context.d.ts",
      "import": "./dist/context.js"
    }
  },
  "scripts": {
    "build": "vite build",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --fix --type-aware",
    "test": "vitest run --config ../../vitest.config.ts --project=app-api",
    "test:integration": "vitest run --config ../../vitest.config.ts --project=app-api --include='**/*.test.ts'",
    "test:unit": "vitest run --config ../../vitest.config.ts --project=app-api --include='**/*.spec.ts'",
    "typecheck": "tsc --noEmit -p tsconfig.lib.json && tsc --noEmit -p tsconfig.spec.json"
  },
  "devDependencies": {
    "@cat/agent-tools": "workspace:*",
    "@cat/test-utils": "workspace:*",
    "unplugin-dts": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@cat/agent": "workspace:*",
    "@cat/agent-tools": "workspace:*",
    "@cat/auth": "workspace:*",
    "@cat/domain": "workspace:*",
    "@cat/message": "workspace:*",
    "@cat/operations": "workspace:*",
    "@cat/permissions": "workspace:*",
    "@cat/plugin-core": "workspace:*",
    "@cat/server-shared": "workspace:*",
    "@cat/shared": "workspace:*",
    "@cat/workflow": "workspace:*",
    "@hono/mcp": "^0.2.4",
    "@hono/node-ws": "^1.3.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@orpc/client": "^1.13.2",
    "@orpc/experimental-pino": "^1.13.2",
    "@orpc/server": "^1.13.2",
    "hono": "^4.11.4",
    "pino": "^10.1.0",
    "telefunc": "^0.2.17",
    "vike": "^0.4.255",
    "zod": "catalog:"
  },
  "nx": {
    "implicitDependencies": [
      "!@cat/test-utils"
    ]
  }
}
