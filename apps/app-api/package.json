{
  "name": "@cat/app-api",
  "version": "0.1.0",
  "keywords": [
    "cat",
    "plugins",
    "types",
    "typescript"
  ],
  "license": "MIT",
  "files": [
    "dist",
    "package.json"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./app": {
      "types": "./dist/app.d.ts",
      "import": "./dist/app.js"
    },
    "./orpc/router": {
      "types": "./dist/orpc/router.d.ts",
      "import": "./dist/orpc/router.js"
    },
    "./context": {
      "types": "./dist/utils/context.d.ts",
      "import": "./dist/context.js"
    }
  },
  "devDependencies": {
    "@cat/agent-tools": "workspace:*",
    "@cat/oxlint-plugin": "workspace:*",
    "@cat/test-utils": "workspace:*",
    "unplugin-dts": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@cat/agent": "workspace:*",
    "@cat/agent-tools": "workspace:*",
    "@cat/auth": "workspace:*",
    "@cat/domain": "workspace:*",
    "@cat/message": "workspace:*",
    "@cat/operations": "workspace:*",
    "@cat/permissions": "workspace:*",
    "@cat/plugin-core": "workspace:*",
    "@cat/server-shared": "workspace:*",
    "@cat/shared": "workspace:*",
    "@cat/vcs": "workspace:*",
    "@cat/workflow": "workspace:*",
    "@hono/mcp": "^0.3.0",
    "@hono/node-ws": "^1.3.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@orpc/client": "^1.14.6",
    "@orpc/experimental-pino": "^1.14.6",
    "@orpc/server": "^1.14.6",
    "hono": "^4.12.25",
    "pino": "^10.3.1",
    "telefunc": "^0.2.20",
    "vike": "^0.4.259",
    "zod": "catalog:"
  }
}
