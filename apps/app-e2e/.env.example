DATABASE_URL="postgresql://user:pass@localhost:5432/cat_e2e?schema=public"
REDIS_URL="redis://localhost:6379"
PORT=3000

# If the default ports (5432 / 6379) conflict with other local services,
# override them here AND adjust DATABASE_URL / REDIS_URL accordingly:
# CAT_E2E_POSTGRES_HOST_PORT=35432
# CAT_E2E_REDIS_HOST_PORT=36379

# Set to "true" to automatically run `docker compose down` after tests finish.
# Useful for CI or one-shot local runs; leave unset for iterative local dev.
# E2E_COMPOSE_TEARDOWN=true