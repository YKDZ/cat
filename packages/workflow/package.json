{
  "name": "@cat/workflow",
  "version": "0.1.0",
  "description": "DAG-based workflow graph executor",
  "license": "GPL-3.0-only",
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tasks": {
      "types": "./dist/workflow/index.d.ts",
      "import": "./dist/workflow/index.js"
    }
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --fix --type-aware",
    "test": "vitest run --config ../../vitest.config.ts --project=workflow",
    "test:integration": "vitest run --config ../../vitest.config.ts --project=workflow-integration",
    "test:unit": "vitest run --config ../../vitest.config.ts --project=workflow",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@cat/test-utils": "workspace:*",
    "@types/node": "catalog:",
    "dotenv": "^17.4.1",
    "unplugin-dts": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@cat/core": "workspace:*",
    "@cat/domain": "workspace:*",
    "@cat/graph": "workspace:*",
    "@cat/operations": "workspace:*",
    "@cat/plugin-core": "workspace:*",
    "@cat/server-shared": "workspace:*",
    "@cat/shared": "workspace:*",
    "zod": "catalog:"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "nx": {
    "implicitDependencies": [
      "!test-utils"
    ]
  }
}
