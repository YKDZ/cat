{
  "name": "@cat/source-collector",
  "version": "0.1.0",
  "license": "MIT",
  "bin": {
    "source-collector": "./dist/cli.js"
  },
  "type": "module",
  "main": "./src/index.ts",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./src/index.ts"
    },
    "./extractor": {
      "types": "./dist/extractor.d.ts",
      "import": "./src/extractor.ts"
    }
  },
  "dependencies": {
    "@cat/shared": "workspace:*",
    "@vue/compiler-dom": "catalog:",
    "@vue/compiler-sfc": "catalog:",
    "glob": "^13.0.6",
    "ts-morph": "^28.0.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "unplugin-dts": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
