{
  "$schema": "https://json-schema.org/draft-07/schema",
  "title": "CatPlugin Manifest Schema",
  "description": "Schema for plugin system manifest",
  "type": "object",
  "required": ["id", "entry", "version"],
  "properties": {
    "$schema": {
      "description": "Optional JSON Schema identifier (URL or file path)",
      "oneOf": [
        {
          "type": "string",
          "format": "uri"
        },
        {
          "type": "string",
          "pattern": "^(\\.{0,2}/|[A-Za-z]:\\\\).+"
        }
      ]
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?:[A-Za-z0-9\\-_.!~*'()]+|%[0-9A-Fa-f]{2})+$",
      "description": "Unique plugin identifier. It needs to be a string that can be used for URL fragments"
    },
    "entry": {
      "type": "string",
      "description": "Entry file path (relative or absolute)"
    },
    "version": {
      "type": "string",
      "description": "Plugin version"
    },
    "iconURL": {
      "type": "string",
      "format": "uri",
      "description": "Icon URL for the plugin"
    },
    "services": {
      "type": "array",
      "description": "Services plugin provided",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Service ID (required for static services, optional for dynamic)"
          },
          "type": {
            "type": "string",
            "enum": [
              "TERM_EXTRACTOR",
              "TERM_ALIGNER",
              "QA_CHECKER",
              "TOKENIZER",
              "TRANSLATION_ADVISOR",
              "FILE_IMPORTER",
              "FILE_EXPORTER",
              "STORAGE_PROVIDER",
              "AUTH_FACTOR",
              "TEXT_VECTORIZER",
              "VECTOR_STORAGE",
              "LLM_PROVIDER",
              "RERANK_PROVIDER",
              "AGENT_TOOL_PROVIDER",
              "AGENT_CONTEXT_PROVIDER",
              "NLP_WORD_SEGMENTER",
              "EMAIL_PROVIDER"
            ]
          },
          "dynamic": {
            "type": "boolean",
            "default": false,
            "description": "Whether this service is dynamically registered at runtime based on configuration"
          }
        },
        "required": ["type"],
        "additionalProperties": false,
        "if": {
          "properties": {
            "dynamic": {
              "not": {
                "const": true
              }
            }
          }
        },
        "then": {
          "required": ["id", "type"]
        }
      }
    },
    "config": {
      "description": "Standard JSON Schema for this config",
      "$ref": "https://json-schema.org/draft-07/schema"
    },
    "components": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "url": {
            "type": "string"
          },
          "slot": {
            "type": "string"
          },
          "skeleton": {
            "type": "string"
          }
        },
        "required": ["id", "url", "slot"],
        "additionalProperties": false
      }
    },
    "permissions": {
      "type": "array",
      "description": "Required permissions for this plugin. Users confirm during installation.",
      "items": {
        "type": "object",
        "properties": {
          "objectType": {
            "type": "string",
            "enum": [
              "project",
              "document",
              "glossary",
              "memory",
              "translation",
              "element",
              "user",
              "setting",
              "system",
              "agent_definition",
              "task"
            ]
          },
          "relations": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "superadmin",
                "admin",
                "owner",
                "editor",
                "viewer",
                "member"
              ]
            },
            "minItems": 1
          },
          "reason": {
            "type": "string",
            "description": "Human-readable reason for needing this permission"
          }
        },
        "required": ["objectType", "relations"],
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
