{
  "name": "@cat/plugin-core",
  "version": "0.1.0",
  "description": "Plugin system core: service registry, component registry, discovery",
  "keywords": [
    "cat",
    "plugins",
    "types",
    "typescript"
  ],
  "license": "MIT",
  "files": [
    "dist",
    "package.json"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client.js"
    }
  },
  "scripts": {
    "build": "vite build",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --fix --type-aware",
    "test": "vitest run --config ../../vitest.config.ts --project=unit-plugin-core",
    "test:integration": "vitest run --config ../../vitest.config.ts --project=unit-plugin-core --include='**/*.test.ts'",
    "test:unit": "vitest run --config ../../vitest.config.ts --project=unit-plugin-core --include='**/*.spec.ts'",
    "typecheck": "tsc --noEmit -p tsconfig.lib.json && tsc --noEmit -p tsconfig.spec.json"
  },
  "devDependencies": {
    "@cat/domain": "workspace:*",
    "hono": "^4.12.12",
    "unplugin-dts": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@cat/domain": "workspace:*",
    "@cat/shared": "workspace:*",
    "dompurify": "^3.3.1",
    "vue": "catalog:",
    "zod": "catalog:"
  }
}
