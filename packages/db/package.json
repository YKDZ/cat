{
  "name": "@cat/db",
  "version": "0.1.0",
  "description": "Database layer: Drizzle ORM schemas and Redis client",
  "files": [
    "src",
    "dist",
    "drizzle/",
    "package.json",
    "drizzle.config.ts"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "codegen:schemas": "tsx src/zod/codegen.ts",
    "drizzle:generate": "drizzle-kit generate",
    "drizzle:migrate": "drizzle-kit migrate",
    "drizzle:studio": "drizzle-kit studio --host 0.0.0.0 --port 4983"
  },
  "dependencies": {
    "pg": "^8.20.0",
    "redis": "^5.12.1"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "catalog:",
    "drizzle-seed": "^0.3.1",
    "unplugin-dts": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@cat/shared": "workspace:*",
    "cldr-core": "^48.0.0",
    "dotenv": "^17.2.3",
    "drizzle-orm": "catalog:",
    "zod": "catalog:"
  }
}
