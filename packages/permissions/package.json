{
  "name": "@cat/permissions",
  "version": "0.1.0",
  "description": "Permission system: ReBAC-based access control",
  "keywords": [
    "cat",
    "permissions",
    "rebac",
    "typescript"
  ],
  "license": "MIT",
  "files": [
    "dist",
    "src",
    "package.json"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "vite build",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --fix --type-aware",
    "typecheck": "tsc --noEmit -p tsconfig.lib.json"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "unplugin-dts": "1.0.0-beta.6",
    "vite": "8.0.0"
  },
  "peerDependencies": {
    "@cat/core": "workspace:*",
    "@cat/domain": "workspace:*",
    "@cat/shared": "workspace:*",
    "zod": "^4.3.6"
  }
}
