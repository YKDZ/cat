{
  "name": "@cat/graph",
  "version": "0.0.1",
  "description": "Storage-agnostic graph core: types, blackboard, condition evaluation",
  "license": "MIT",
  "files": [
    "dist",
    "src",
    "package.json"
  ],
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "vite build",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --fix --type-aware",
    "test": "vitest run --config ../../vitest.config.ts --project=unit-graph",
    "typecheck": "tsc --noEmit -p tsconfig.lib.json"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "unplugin-dts": "1.0.0-beta.6",
    "vite": "^8.0.3",
    "vitest": "^4.1.2",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "zod": "^4.3.6"
  }
}
