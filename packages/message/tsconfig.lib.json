{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "tsBuildInfoFile": "dist/tsconfig.lib.tsbuildinfo",
    "forceConsistentCasingInFileNames": true,
    "types": ["node", "vite/client"],
    "paths": { "@/*": ["./src/*"] },
    "composite": true
  },
  "include": ["src/**/*.ts"],
  "references": [
    { "path": "../core/tsconfig.lib.json" },
    { "path": "../shared/tsconfig.lib.json" },
    { "path": "../domain/tsconfig.lib.json" },
    { "path": "../plugin-core/tsconfig.lib.json" },
    { "path": "../server-shared/tsconfig.lib.json" }
  ],
  "exclude": [
    "vite.config.ts",
    "vitest.config.ts",
    "src/**/*.test.ts",
    "src/**/*.spec.ts"
  ]
}
