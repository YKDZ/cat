{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "tsBuildInfoFile": "dist/tsconfig.lib.tsbuildinfo",
    "forceConsistentCasingInFileNames": true,
    "types": ["node"],
    "paths": {
      "@/*": ["./src/*"]
    },
    "composite": true
  },
  "include": ["src/**/*.ts"],
  "references": [
    {
      "path": "../shared/tsconfig.lib.json"
    },
    {
      "path": "../domain/tsconfig.lib.json"
    }
  ],
  "exclude": [
    "vite.config.ts",
    "vitest.config.ts",
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "src/**/__tests__/**"
  ]
}
