{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist-spec",
    "tsBuildInfoFile": "dist-spec/tsconfig.spec.tsbuildinfo",
    "types": ["node", "vitest/globals"],
    "paths": {
      "@/*": ["./src/*"]
    },
    "composite": true
  },
  "include": ["src/**/*.spec.ts", "src/**/*.test.ts", "src/**/__tests__/**"],
  "references": [
    {
      "path": "./tsconfig.lib.json"
    }
  ]
}
