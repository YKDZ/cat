{
  "name": "@cat/agent",
  "version": "0.1.0",
  "license": "GPL-3.0-only",
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./workflow": {
      "types": "./dist/workflow/index.d.ts",
      "import": "./dist/workflow/index.js"
    }
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --fix --type-aware",
    "test": "vitest run --config ../../vitest.config.ts --project=agent",
    "test:integration": "vitest run --config ../../vitest.config.ts --project=agent-integration",
    "test:unit": "vitest run --config ../../vitest.config.ts --project=agent",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@cat/domain": "workspace:*",
    "@cat/test-utils": "workspace:*",
    "@types/node": "^25.5.0",
    "dotenv": "^17.3.1",
    "unplugin-dts": "1.0.0-beta.6",
    "vite": "8.0.0",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "@cat/domain": "workspace:*",
    "@cat/operations": "workspace:*",
    "@cat/plugin-core": "workspace:*",
    "@cat/server-shared": "workspace:*",
    "@cat/shared": "workspace:*",
    "zod": "^4.3.6"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "nx": {
    "implicitDependencies": [
      "!test-utils"
    ]
  }
}
