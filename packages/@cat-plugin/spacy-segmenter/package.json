{
  "name": "@cat-plugin/spacy-segmenter",
  "version": "0.1.0",
  "keywords": [
    "cat",
    "nlp",
    "plugins",
    "spacy",
    "typescript"
  ],
  "license": "MIT",
  "files": [
    "dist",
    "manifest.json",
    "package.json"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "vite build",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --fix --type-aware",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.spec.json"
  },
  "dependencies": {
    "undici": "7.18.2"
  },
  "devDependencies": {
    "vite": "8.0.0"
  },
  "peerDependencies": {
    "@cat/plugin-core": "workspace:*",
    "@cat/shared": "workspace:*",
    "zod": "^4.3.6"
  }
}
