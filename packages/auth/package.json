{
  "name": "@cat/auth",
  "version": "0.0.1",
  "description": "DAG-based authentication flow engine",
  "license": "GPL-3.0-only",
  "files": [
    "dist",
    "src",
    "package.json"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "vite build",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --fix --type-aware",
    "test": "vitest run --config ../../vitest.config.ts --project=unit-auth",
    "typecheck": "tsc --noEmit -p tsconfig.lib.json"
  },
  "devDependencies": {
    "@cat/core": "workspace:*",
    "@cat/graph": "workspace:*",
    "@cat/shared": "workspace:*",
    "@types/node": "catalog:",
    "unplugin-dts": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:",
    "zod": "catalog:"
  },
  "peerDependencies": {
    "@cat/core": "workspace:*",
    "@cat/graph": "workspace:*",
    "@cat/shared": "workspace:*",
    "redis": "^5.11.0",
    "zod": "catalog:"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
