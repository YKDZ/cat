{
  "name": "@cat/server-shared",
  "version": "0.1.0",
  "description": "Shared server utilities",
  "keywords": [
    "cat",
    "server",
    "shared",
    "typescript"
  ],
  "license": "MIT",
  "files": [
    "dist",
    "package.json"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "vite build",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --fix --type-aware",
    "typecheck": "tsc --noEmit -p tsconfig.lib.json"
  },
  "dependencies": {
    "pino": "^10.3.1",
    "redis": "^5.11.0"
  },
  "devDependencies": {
    "pino-pretty": "^13.1.3",
    "unplugin-dts": "1.0.0-beta.6",
    "vite": "^8.0.7"
  },
  "peerDependencies": {
    "@cat/domain": "workspace:*",
    "@cat/plugin-core": "workspace:*",
    "@cat/shared": "workspace:*",
    "zod": "^4.3.6"
  }
}
