{
  "name": "@cat/server-shared",
  "version": "0.1.0",
  "description": "Shared server utilities",
  "keywords": [
    "cat",
    "server",
    "shared",
    "typescript"
  ],
  "license": "MIT",
  "files": [
    "dist",
    "package.json"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./plugin": {
      "types": "./dist/plugin.d.ts",
      "import": "./dist/plugin.js"
    }
  },
  "dependencies": {
    "pino": "^10.3.1",
    "redis": "^5.11.0"
  },
  "devDependencies": {
    "pino-pretty": "^13.1.3",
    "unplugin-dts": "catalog:",
    "vite": "catalog:"
  },
  "peerDependencies": {
    "@cat/core": "workspace:*",
    "@cat/domain": "workspace:*",
    "@cat/plugin-core": "workspace:*",
    "@cat/shared": "workspace:*",
    "zod": "catalog:"
  }
}
