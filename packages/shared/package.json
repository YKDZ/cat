{
  "name": "@cat/shared",
  "version": "0.1.0",
  "description": "Shared Zod schemas, type definitions, and utility functions",
  "keywords": [
    "cat",
    "plugins",
    "types",
    "typescript"
  ],
  "license": "MIT",
  "files": [
    "dist",
    "package.json"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils.js"
    },
    "./schema/json": {
      "types": "./dist/schema/json.d.ts",
      "import": "./dist/schema/json.js"
    },
    "./schema/misc": {
      "types": "./dist/schema/misc.d.ts",
      "import": "./dist/schema/misc.js"
    },
    "./schema/ce": {
      "types": "./dist/schema/ce.d.ts",
      "import": "./dist/schema/ce.js"
    },
    "./schema/plugin": {
      "types": "./dist/schema/plugin.d.ts",
      "import": "./dist/schema/plugin.js"
    },
    "./schema/enum": {
      "types": "./dist/schema/enum.d.ts",
      "import": "./dist/schema/enum.js",
      "require": "./dist/schema/enum.cjs"
    },
    "./schema/drizzle/document": {
      "types": "./dist/schema/drizzle/document.d.ts",
      "import": "./dist/schema/drizzle/document.js"
    },
    "./schema/drizzle/file": {
      "types": "./dist/schema/drizzle/file.d.ts",
      "import": "./dist/schema/drizzle/file.js"
    },
    "./schema/drizzle/qa": {
      "types": "./dist/schema/drizzle/qa.d.ts",
      "import": "./dist/schema/drizzle/qa.js"
    },
    "./schema/drizzle/glossary": {
      "types": "./dist/schema/drizzle/glossary.d.ts",
      "import": "./dist/schema/drizzle/glossary.js"
    },
    "./schema/drizzle/agent": {
      "types": "./dist/schema/drizzle/agent.d.ts",
      "import": "./dist/schema/drizzle/agent.js"
    },
    "./schema/drizzle/kanban": {
      "types": "./dist/schema/drizzle/kanban.d.ts",
      "import": "./dist/schema/drizzle/kanban.js"
    },
    "./schema/drizzle/changeset": {
      "types": "./dist/schema/drizzle/changeset.d.ts",
      "import": "./dist/schema/drizzle/changeset.js"
    },
    "./schema/drizzle/memory": {
      "types": "./dist/schema/drizzle/memory.d.ts",
      "import": "./dist/schema/drizzle/memory.js"
    },
    "./schema/drizzle/misc": {
      "types": "./dist/schema/drizzle/misc.d.ts",
      "import": "./dist/schema/drizzle/misc.js"
    },
    "./schema/drizzle/plugin": {
      "types": "./dist/schema/drizzle/plugin.d.ts",
      "import": "./dist/schema/drizzle/plugin.js"
    },
    "./schema/drizzle/project": {
      "types": "./dist/schema/drizzle/project.d.ts",
      "import": "./dist/schema/drizzle/project.js"
    },
    "./schema/drizzle/translation": {
      "types": "./dist/schema/drizzle/translation.d.ts",
      "import": "./dist/schema/drizzle/translation.js"
    },
    "./schema/drizzle/user": {
      "types": "./dist/schema/drizzle/user.d.ts",
      "import": "./dist/schema/drizzle/user.js"
    },
    "./schema/drizzle/vector": {
      "types": "./dist/schema/drizzle/vector.d.ts",
      "import": "./dist/schema/drizzle/vector.js"
    },
    "./schema/drizzle/comment": {
      "types": "./dist/schema/drizzle/comment.d.ts",
      "import": "./dist/schema/drizzle/comment.js",
      "require": "./dist/schema/drizzle/comment.cjs"
    },
    "./schema/agent": {
      "types": "./dist/schema/agent.d.ts",
      "import": "./dist/schema/agent.js"
    },
    "./schema/nlp": {
      "types": "./dist/schema/nlp.d.ts",
      "import": "./dist/schema/nlp.js"
    },
    "./schema/permission": {
      "types": "./dist/schema/permission.d.ts",
      "import": "./dist/schema/permission.js"
    },
    "./schema/term-recall": {
      "types": "./dist/schema/term-recall.d.ts",
      "import": "./dist/schema/term-recall.js"
    },
    "./schema/recall": {
      "types": "./dist/schema/recall.d.ts",
      "import": "./dist/schema/recall.js"
    }
  },
  "dependencies": {
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "unplugin-dts": "catalog:",
    "vite": "catalog:"
  },
  "peerDependencies": {
    "zod": "catalog:"
  }
}
