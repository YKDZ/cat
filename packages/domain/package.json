{
  "name": "@cat/domain",
  "version": "0.1.0",
  "description": "Domain layer: CQRS Commands and Queries, core business logic",
  "files": [
    "dist",
    "src",
    "package.json"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./events": {
      "types": "./dist/events/index.d.ts",
      "import": "./dist/events/index.js"
    },
    "./capabilities": {
      "types": "./dist/capabilities/index.d.ts",
      "import": "./dist/capabilities/index.js"
    },
    "./cache": {
      "types": "./dist/cache/index.d.ts",
      "import": "./dist/cache/index.js"
    }
  },
  "scripts": {
    "build": "vite build",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --fix --type-aware",
    "test": "vitest run --config ../../vitest.config.ts --project=domain",
    "test:integration": "vitest run --config ../../vitest.config.ts --project=domain --include='**/*.test.ts'",
    "test:unit": "vitest run --config ../../vitest.config.ts --project=domain --include='**/*.spec.ts'",
    "typecheck": "tsc --noEmit -p tsconfig.lib.json && tsc --noEmit -p tsconfig.spec.json"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "unplugin-dts": "1.0.0-beta.6",
    "vite": "8.0.3",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "@cat/core": "workspace:*",
    "@cat/db": "workspace:*",
    "@cat/shared": "workspace:*",
    "dotenv": "^17.2.3",
    "zod": "^4.3.6"
  }
}
