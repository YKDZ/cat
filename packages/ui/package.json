{
  "name": "@cat/ui",
  "version": "0.1.0",
  "license": "GPL-3.0-only",
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "vite build",
    "component:sync": "node scripts/sync-shadcn-components.js",
    "component:sync:check": "node scripts/sync-shadcn-components.js --check",
    "dev": "vite build --watch",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint --disable-nested-config --type-aware",
    "lint:fix": "oxlint --fix --disable-nested-config --type-aware",
    "test": "vitest run --config ../../vitest.config.ts --project=unit-ui",
    "typecheck": "tsc --noEmit -p tsconfig.json && vue-tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@vue-flow/controls": "^1.1.3",
    "@vue-flow/core": "^1.48.2",
    "@vue-flow/minimap": "^1.5.4",
    "@vueuse/core": "^14.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "elkjs": "^0.11.1",
    "lucide-vue-next": "^1.0.0",
    "tailwind-merge": "^3.5.0",
    "vee-validate": "^4.15.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/vue-table": "^8.21.3",
    "@types/node": "^25.5.2",
    "@vue/tsconfig": "^0.9.1",
    "shadcn-vue": "^2.5.1",
    "unplugin-dts": "1.0.0-beta.6",
    "vite": "^8.0.3",
    "vue-tsc": "^3.2.6"
  },
  "peerDependencies": {
    "@vue-flow/controls": "^1.1.3",
    "@vue-flow/core": "^1.48.2",
    "@vue-flow/minimap": "^1.5.4",
    "elkjs": "^0.11.1",
    "reka-ui": "^2.8.2",
    "tailwindcss": "^4.2.0",
    "vike-vue": "^0.9.11",
    "vue": "^3.5.28",
    "vue-sonner": "^2.0.9",
    "zod": "^4.3.6"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
