{
  "name": "root",
  "root": ".",
  "targets": {
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "oxlint --type-aware *.ts scripts/**/*.ts"
      }
    },
    "lint:fix": {
      "executor": "nx:run-commands",
      "options": {
        "command": "oxlint --fix --type-aware *.ts scripts/**/*.ts"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p scripts/tsconfig.json"
      }
    },
    "fmt": {
      "executor": "nx:run-commands",
      "options": {
        "command": "oxfmt *.ts *.json scripts/**/*.ts scripts/**/*.js .github/**/* .devcontainer/**/* __mocks__/**/* .vscode/**/*"
      }
    },
    "fmt:check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "oxfmt --check *.ts *.json scripts/**/*.ts scripts/**/*.js .github/**/* .devcontainer/**/* __mocks__/**/* .vscode/**/*"
      }
    }
  }
}
