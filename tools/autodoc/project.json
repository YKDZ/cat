{
  "name": "autodoc",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "tools/autodoc/src",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsup",
        "cwd": "tools/autodoc"
      }
    },
    "generate": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node tools/autodoc/dist/cli.js"
      },
      "dependsOn": ["build"]
    },
    "check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node tools/autodoc/dist/cli.js --check"
      },
      "dependsOn": ["build"]
    }
  }
}
