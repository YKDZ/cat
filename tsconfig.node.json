{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true
  },
  "include": [
    "vitest.config.ts",
    "oxlint.config.ts",
    "oxfmt.config.ts",
    "apps/*/oxlint.config.ts",
    "packages/*/oxlint.config.ts",
    "@cat-plugin/*/oxlint.config.ts",
    "tools/*/oxlint.config.ts"
  ]
}
