{
  "name": "@cat-plugin/openai-vectorizer",
  "version": "0.1.0",
  "keywords": [
    "cat",
    "plugins",
    "types",
    "typescript"
  ],
  "license": "MIT",
  "files": [
    "dist",
    "manifest.json",
    "package.json"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "vite build",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint --disable-nested-config --type-aware",
    "lint:fix": "oxlint --fix --disable-nested-config --type-aware",
    "typecheck": "tsc --noEmit -p tsconfig.app.json"
  },
  "dependencies": {
    "openai": "^6.33.0"
  },
  "devDependencies": {
    "vite": "^8.0.3"
  },
  "peerDependencies": {
    "@cat/plugin-core": "workspace:*",
    "@cat/shared": "workspace:*",
    "zod": "^4.3.6"
  }
}
