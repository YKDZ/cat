{
  "name": "@cat-plugin/totp-mfa-provider",
  "version": "0.1.0",
  "keywords": [
    "cat",
    "plugins",
    "types",
    "typescript"
  ],
  "license": "MIT",
  "files": [
    "dist",
    "manifest.json",
    "package.json"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite dev",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint --disable-nested-config --type-aware",
    "lint:fix": "oxlint --fix --disable-nested-config --type-aware",
    "typecheck": "tsc --noEmit -p tsconfig.app.json"
  },
  "dependencies": {
    "qrcode": "^1.5.4",
    "speakeasy": "^2.0.0"
  },
  "devDependencies": {
    "@types/qrcode": "^1.5.6",
    "@types/speakeasy": "^2.0.10",
    "@vitejs/plugin-vue": "^6.0.5",
    "hono": "^4.12.10",
    "vite": "^8.0.3",
    "vue": "^3.5.32",
    "vue-tsc": "^3.2.6"
  },
  "peerDependencies": {
    "@cat/plugin-core": "workspace:*",
    "@cat/shared": "workspace:*",
    "zod": "^4.3.6"
  }
